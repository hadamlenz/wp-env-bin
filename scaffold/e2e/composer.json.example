{
    "name": "your-vendor/your-plugin",
    "require-dev": {
        "your-vendor/test-theme": "^1.0",
        "your-vendor/test-plugin": "^1.0"
    },
    "repositories": [
        {
            "type": "composer",
            "url": "https://your-composer-repo/packages.json",
            "only": [
                "your-vendor/test-theme",
                "your-vendor/test-plugin"
            ]
        }
    ],
    "extra": {
        "installer-paths": {
            "./themes/{$name}/": [
                "type:wordpress-theme"
            ],
            "./plugins/{$name}": [
                "type:wordpress-plugin"
            ]
        }
    },
    "config": {
        "platform": {
            "php": "8.3"
        },
        "allow-plugins": {
            "composer/installers": true
        }
    }
}
