{
    "name": "wp-env-bin",
    "require-dev": {},
    "repositories": [],
    "extra": {
        "installer-paths": {
            "./themes/{$name}/": [
                "type:wordpress-theme"
            ],
            "./plugins/{$name}": [
                "type:wordpress-plugin"
            ]
        }
    },
    "config": {
        "platform": {
            "php": "8.3"
        },
        "allow-plugins": {
            "composer/installers": true
        }
    }
}
