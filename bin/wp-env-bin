#!/usr/bin/env node

/**
 * wp-env-bin CLI entry point.
 *
 * Parses the first two CLI arguments and dispatches to the appropriate
 * command module or interactive prompt handler. All commands follow the
 * pattern:
 *
 *   wp-env-bin <command> [subcommand] [args...]
 *
 * Unknown commands and missing subcommands print a yellow usage hint and exit
 * cleanly. Any unhandled promise rejection is caught at the bottom, printed in
 * red, and exits with code 1.
 */

const path = require("path");
const chalk = require("chalk");

/** The primary command (process.argv[2]), e.g. "clean", "db", "env". */
const command = process.argv[2];

/** The subcommand (process.argv[3]), e.g. "install", "get", "help". */
const subcommand = process.argv[3];

// ─── Commands (business logic) ────────────────────────────────────────────────
const { setup } = require("../commands/setup");
const { scaffoldCommand } = require("../commands/scaffold");
const { runWpEnv, runWpEnvE2e } = require("../commands/env");
const { composerUpdate, composerE2eInstall, composerE2eUpdate } = require("../commands/composer");
const { cleanThemes, cleanPlugins, cleanAssets, cleanAll } = require("../commands/clean");
const { infoCommand } = require("../commands/info");
const { statusCommand } = require("../commands/status");
const { generateE2eTests, runE2eTests, updateE2eManagedFiles } = require("../commands/e2e");
const { putHtaccess } = require("../commands/htaccess");
const { run } = require("../lib/utils/run");
const { requireDir } = require("../lib/env/check");

// ─── Help ─────────────────────────────────────────────────────────────────────
const {
	help, configHelp, scaffoldHelp, dbHelp, htaccessHelp, envHelp,
	e2eEnvHelp, compareHelp, e2eHelp, composerHelp, composerE2eHelp, cleanHelp, statusHelp,
} = require("../commands/help");

// ─── Prompt handlers (interactive layer) ─────────────────────────────────────
const {
	configInstallPrompt, configUpdatePrompt, configSwitchPrompt,
	configCreatePrompt, configDeletePrompt,
} = require("../lib/prompts/config");
const { dbGetPrompt, dbProcessPrompt, dbUsePrompt } = require("../lib/prompts/db");
const { composerGetPrompt, composerMakePrompt } = require("../lib/prompts/composer");
const { e2eScaffoldPrompt } = require("../lib/prompts/e2e");
const { envSyncPrompt } = require("../lib/prompts/env");
const { htaccessMakePrompt } = require("../lib/prompts/htaccess");
const { visualComparePrompt } = require("../lib/prompts/visual");

// ─── init ─────────────────────────────────────────────────────────────────────

/**
 * Main CLI dispatcher.
 *
 * Reads `command` and `subcommand` from `process.argv` and routes execution to
 * the appropriate command module or interactive prompt handler. Each `case`
 * block mirrors a top-level CLI command documented in the project README.
 *
 * @async
 * @returns {Promise<void>}
 */
async function init() {
	switch (command) {

		// ── clean ──────────────────────────────────────────────────────────────
		// Removes generated or downloaded assets from the local environment.
		// Subcommands map directly to the type of artifact to delete.
		// Example: wp-env-bin clean all
		case "clean": {
			if (subcommand === "all") {
				// Remove all generated artifacts (themes, plugins, and assets).
				// Example: wp-env-bin clean all
				cleanAll();
			} else if (subcommand === "themes") {
				// Remove only the themes directory contents.
				// Example: wp-env-bin clean themes
				cleanThemes();
			} else if (subcommand === "plugins") {
				// Remove only the plugins directory contents.
				// Example: wp-env-bin clean plugins
				cleanPlugins();
			} else if (subcommand === "assets") {
				// Remove only the assets directory contents.
				// Example: wp-env-bin clean assets
				cleanAssets();
			} else if (subcommand === "help" || subcommand === "--help" || subcommand === "-h") {
				// Example: wp-env-bin clean --help
				cleanHelp();
			} else {
				console.log(chalk.yellow(
				"Unknown clean subcommand. Try:\n" +
				"  wp-env-bin clean all\n" +
				"  wp-env-bin clean themes\n" +
				"  wp-env-bin clean plugins\n" +
				"  wp-env-bin clean assets"
			));
			}
			break;
		}

		// ── composer ───────────────────────────────────────────────────────────
		// Manages Composer dependencies for the WordPress project.
		// The `--` escape hatch allows running arbitrary Composer commands
		// scoped to the project's wp-env-bin/ directory.
		// Example: wp-env-bin composer install
		case "composer": {
			if (subcommand === "install") {
				// Install Composer dependencies. Extra args (argv[4+]) are forwarded
				// to the setup command (e.g. --no-dev).
				// Example: wp-env-bin composer install
				// Example: wp-env-bin composer install --no-dev
				setup(process.argv.slice(4));
			} else if (subcommand === "update") {
				// Update all Composer dependencies to their latest allowed versions.
				// Example: wp-env-bin composer update
				composerUpdate();
			} else if (subcommand === "get") {
				// Interactively download a Composer package.
				// Supports optional --path and --url flags to pre-populate prompts.
				// Example: wp-env-bin composer get
				// Example: wp-env-bin composer get --path vendor/my-package --url https://example.com/package.zip
				const pathIdx = process.argv.indexOf("--path");
				const runtimePath = pathIdx !== -1 ? process.argv[pathIdx + 1] : null;
				const urlIdx = process.argv.indexOf("--url");
				const runtimeUrl = urlIdx !== -1 ? process.argv[urlIdx + 1] : null;
				await composerGetPrompt(runtimePath, runtimeUrl);
			} else if (subcommand === "make") {
				// Interactively create a composer.json configuration file.
				// Example: wp-env-bin composer make
				await composerMakePrompt();
			} else if (subcommand === "help" || subcommand === "--help" || subcommand === "-h") {
				// Example: wp-env-bin composer --help
				composerHelp();
			} else if (subcommand === "--") {
				// Escape hatch: run any arbitrary Composer command inside the
				// project's wp-env-bin/ directory.
				// Example: wp-env-bin composer -- require wpackagist-plugin/akismet
				// Example: wp-env-bin composer -- remove wpackagist-plugin/akismet
				const composerArgs = process.argv.slice(4);
				if (!composerArgs.length) {
					console.log("Usage: wp-env-bin composer -- <composer command> [args...]");
					console.log("Example: wp-env-bin composer -- remove wpackagist-plugin/akismet");
				} else {
					// Resolve the wp-env-bin subdirectory and verify it exists before
					// executing — prevents silent failures when run from the wrong directory.
					const composerDir = path.join(process.cwd(), "wp-env-bin");
					requireDir(composerDir, "Run this command from your project root (the directory containing wp-env-bin/).");
					run(`composer ${composerArgs.join(" ")}`, { cwd: composerDir, stdio: "inherit" });
				}
			} else {
				console.log(chalk.yellow(
				"Unknown composer subcommand. Try:\n" +
				"  wp-env-bin composer install\n" +
				"  wp-env-bin composer update\n" +
				"  wp-env-bin composer get\n" +
				"  wp-env-bin composer make\n" +
				"  wp-env-bin composer -- <any composer command>"
			));
			}
			break;
		}

		// ── config ─────────────────────────────────────────────────────────────
		// Manages wp-env JSON config files that define the WordPress environment
		// (plugins, themes, mappings, etc.).
		// Example: wp-env-bin config create
		case "config": {
			if (subcommand === "install") {
				// Deprecated: scaffold + config create should be used instead.
				// Example: wp-env-bin config install  ← deprecated, avoid this
				console.log(chalk.yellow("[Deprecated] `config install` will be removed in a future version."));
				console.log(chalk.yellow("  Use: wp-env-bin scaffold && wp-env-bin config create\n"));
				await configInstallPrompt();
			} else if (subcommand === "update") {
				// Interactively update values in an existing config file.
				// Example: wp-env-bin config update
				await configUpdatePrompt();
			} else if (subcommand === "switch") {
				// Interactively switch the active config to a different preset.
				// Example: wp-env-bin config switch
				await configSwitchPrompt();
			} else if (subcommand === "create") {
				// Interactively create a new wp-env config file from scratch.
				// Example: wp-env-bin config create
				await configCreatePrompt();
			} else if (subcommand === "delete") {
				// Interactively delete an existing config file.
				// Example: wp-env-bin config delete
				await configDeletePrompt();
			} else if (subcommand === "help" || subcommand === "--help" || subcommand === "-h") {
				// Example: wp-env-bin config --help
				configHelp();
			} else {
				console.log(chalk.yellow(
				"Unknown config subcommand. Try:\n" +
				"  wp-env-bin config scaffold\n" +
				"  wp-env-bin config create\n" +
				"  wp-env-bin config install\n" +
				"  wp-env-bin config update\n" +
				"  wp-env-bin config switch\n" +
				"  wp-env-bin config delete"
			));
			}
			break;
		}

		// ── db ─────────────────────────────────────────────────────────────────
		// Database utilities: export, transform, and import SQL files.
		// Example: wp-env-bin db get
		case "db": {
			if (subcommand === "get") {
				// Interactively export / download a database snapshot.
				// Example: wp-env-bin db get
				await dbGetPrompt();
			} else if (subcommand === "process") {
				// Interactively run search-and-replace or other transforms on a
				// database SQL file (e.g. rewrite URLs for local development).
				// Example: wp-env-bin db process
				await dbProcessPrompt();
			} else if (subcommand === "use") {
				// Import an SQL file into the local environment.
				// The file path is passed as the fourth CLI argument (argv[4]).
				// Example: wp-env-bin db use ./backups/production.sql
				await dbUsePrompt(process.argv[4]);
			} else if (subcommand === "help" || subcommand === "--help" || subcommand === "-h") {
				// Example: wp-env-bin db --help
				dbHelp();
			} else {
				console.log(chalk.yellow(
				"Unknown subcommand. Try:\n" +
				"  wp-env-bin db get\n" +
				"  wp-env-bin db process\n" +
				"  wp-env-bin db use <path/to/file.sql>"
			));
			}
			break;
		}

		// ── e2e ────────────────────────────────────────────────────────────────
		// End-to-end (Playwright) test utilities: scaffold, generate, and run
		// tests, plus manage the separate E2E Composer dependencies.
		// Example: wp-env-bin e2e test
		case "e2e": {
			if (subcommand === "help" || subcommand === "--help" || subcommand === "-h") {
				// Example: wp-env-bin e2e --help
				e2eHelp();
			} else if (subcommand === "env") {
				// Pass-through to wp-env scoped to the E2E environment.
				// Shows help when no args are provided.
				// Example: wp-env-bin e2e env start
				// Example: wp-env-bin e2e env stop
				const envArgs = process.argv.slice(4);
				if (!envArgs.length || envArgs[0] === "help" || envArgs[0] === "--help" || envArgs[0] === "-h") {
					e2eEnvHelp();
				} else {
					runWpEnvE2e(envArgs);
				}
			} else if (subcommand === "scaffold") {
				// Interactively create the E2E directory structure and config files.
				// Example: wp-env-bin e2e scaffold
				await e2eScaffoldPrompt();
			} else if (subcommand === "update") {
				// Re-copy managed spec files and regenerate tsconfig.e2e.json with the
				// current install path. Run after upgrading wp-env-bin.
				// Example: wp-env-bin e2e update
				updateE2eManagedFiles();
			} else if (subcommand === "generate") {
				// Generate Playwright test file stubs for a given block type.
				// argv[4] = type ("editor" or "frontend")
				// argv[5+] = additional generator flags (e.g. --file=path/to/block.json)
				// Example: wp-env-bin e2e generate editor --file=src/blocks/my-block/block.json
				// Example: wp-env-bin e2e generate frontend --file=src/blocks/my-block/block.json
				const type = process.argv[4];
				generateE2eTests(type, process.argv.slice(5));
			} else if (subcommand === "test") {
				// Execute the Playwright test suite.
				// argv[4+] are forwarded as-is (e.g. --project=all-blocks-editor).
				// Example: wp-env-bin e2e test
				// Example: wp-env-bin e2e test --project=all-blocks-editor
				runE2eTests(process.argv.slice(4));
			} else if (subcommand === "composer") {
				// Nested composer management scoped to the E2E test environment.
				// Example: wp-env-bin e2e composer install
				const e2eComposerSub = process.argv[4];
				if (e2eComposerSub === "install") {
					// Install E2E-specific Composer dependencies.
					// Example: wp-env-bin e2e composer install
					composerE2eInstall();
				} else if (e2eComposerSub === "update") {
					// Update E2E-specific Composer dependencies.
					// Example: wp-env-bin e2e composer update
					composerE2eUpdate();
				} else if (e2eComposerSub === "help" || e2eComposerSub === "--help" || e2eComposerSub === "-h") {
					// Example: wp-env-bin e2e composer --help
					composerE2eHelp();
				} else {
					console.log(chalk.yellow(
					"Unknown e2e composer subcommand. Try:\n" +
					"  wp-env-bin e2e composer install\n" +
					"  wp-env-bin e2e composer update"
				));
				}
			} else {
				console.log(chalk.yellow(
				"Unknown e2e subcommand. Try:\n" +
				"  wp-env-bin e2e scaffold\n" +
				"  wp-env-bin e2e update\n" +
				"  wp-env-bin e2e test [--project=all-blocks-editor|all-blocks-frontend]\n" +
				"  wp-env-bin e2e generate editor|frontend --file=path/to/block.json\n" +
				"  wp-env-bin e2e composer install\n" +
				"  wp-env-bin e2e composer update"
			));
			}
			break;
		}

		// ── env ────────────────────────────────────────────────────────────────
		// WordPress environment lifecycle management (wraps @wordpress/env).
		// Unknown subcommands are forwarded directly to wp-env, allowing full
		// access to its commands (start, stop, run, etc.) via this binary.
		// Example: wp-env-bin env start
		case "env": {
			if (subcommand === "setup") {
				// Initialise the environment: install plugins, themes, and Composer
				// dependencies. argv[4+] are forwarded as flags.
				// Example: wp-env-bin env setup
				// Example: wp-env-bin env setup --skip-composer
				setup(process.argv.slice(4));
			} else if (subcommand === "sync") {
				// Interactively synchronise the local environment state (e.g. after
				// pulling changes that updated the wp-env config).
				// Example: wp-env-bin env sync
				await envSyncPrompt();
			} else {
				// Pass-through: forward remaining args to the underlying wp-env CLI.
				// Falls back to envHelp() when no args are given or help is requested.
				// Example: wp-env-bin env start
				// Example: wp-env-bin env stop
				// Example: wp-env-bin env run cli wp post list
				const argv = process.argv.slice(3);
				if (!argv.length || argv[0] === "help" || argv[0] === "--help" || argv[0] === "-h") {
					envHelp();
				} else {
					runWpEnv(argv);
				}
			}
			break;
		}

		// ── htaccess ───────────────────────────────────────────────────────────
		// Manage the .htaccess file used by the local WordPress environment.
		// Example: wp-env-bin htaccess make
		case "htaccess": {
			if (subcommand === "make") {
				// Interactively generate a new .htaccess file with prompted values.
				// Example: wp-env-bin htaccess make
				await htaccessMakePrompt();
			} else if (subcommand === "put") {
				// Copy the existing .htaccess file into the environment's web root.
				// Example: wp-env-bin htaccess put
				putHtaccess();
			} else if (subcommand === "help" || subcommand === "--help" || subcommand === "-h") {
				// Example: wp-env-bin htaccess --help
				htaccessHelp();
			} else {
				console.log(chalk.yellow(
				"Unknown subcommand. Try:\n" +
				"  wp-env-bin htaccess make\n" +
				"  wp-env-bin htaccess put"
			));
			}
			break;
		}

		// ── scaffold ───────────────────────────────────────────────────────────
		// Copy the wp-env-bin configuration scaffold into the current project.
		// The destination is always <cwd>/wp-env-bin/.
		// Example: wp-env-bin scaffold
		case "scaffold": {
			if (subcommand === "help" || subcommand === "--help" || subcommand === "-h") {
				// Example: wp-env-bin scaffold --help
				scaffoldHelp();
			} else {
				// Resolve the absolute destination path and run the scaffold command.
				// Example: wp-env-bin scaffold
				const dest = path.join(process.cwd(), "wp-env-bin");
				scaffoldCommand(dest);
			}
			break;
		}

		// ── visual ─────────────────────────────────────────────────────────────
		// Visual regression utilities for comparing screenshots between builds.
		// Example: wp-env-bin visual compare
		case "visual": {
			if (subcommand === "compare") {
				// Run a visual diff comparison. argv[4+] are forwarded as flags
				// (e.g. --baseline, --output).
				// Example: wp-env-bin visual compare
				// Example: wp-env-bin visual compare --baseline ./screenshots/baseline
				await visualComparePrompt(process.argv.slice(4));
			} else if (subcommand === "help" || subcommand === "--help" || subcommand === "-h") {
				// Example: wp-env-bin visual --help
				compareHelp();
			} else {
				console.log(chalk.yellow("Unknown subcommand. Try: wp-env-bin visual compare"));
			}
			break;
		}

		// ── info ───────────────────────────────────────────────────────────────
		// Print diagnostic information about the current project and environment.
		// argv[3+] are forwarded to allow filtering output by topic.
		// Example: wp-env-bin info
		case "info": {
			infoCommand(process.argv.slice(3));
			break;
		}

		// ── status ─────────────────────────────────────────────────────────────
		// Show the active site config and whether wp-env is running.
		// Example: wp-env-bin status
		case "status": {
			if (subcommand === "help" || subcommand === "--help" || subcommand === "-h") {
				statusHelp();
			} else {
				statusCommand();
			}
			break;
		}

		// ── menu ───────────────────────────────────────────────────────────────
		// Guided interactive menu (clack-powered). Launched when no command is
		// given, or when `menu` is explicitly requested.
		// Example: wp-env-bin
		// Example: wp-env-bin menu
		case undefined:
		case "menu": {
			const { menuPrompt } = require("../lib/prompts/menu");
			await menuPrompt();
			break;
		}

		// ── help / fallback ────────────────────────────────────────────────────
		// Show the top-level help menu for any unrecognised command (or when
		// `help` is explicitly requested).
		// Example: wp-env-bin help
		// Example: wp-env-bin --help
		case "help":
		default: {
			help();
			break;
		}
	}
}

// Invoke the dispatcher and handle any unhandled promise rejections by printing
// the error message in red and exiting with a non-zero status code.
init().catch((err) => {
	console.error(chalk.red(err.message || err));
	process.exit(1);
});
