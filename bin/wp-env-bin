#!/usr/bin/env node

const command = process.argv[2];
const subcommand = process.argv[3];

async function init() {
	switch (command) {
		case "config": {
			if (subcommand === "install") {
				const { configInstall } = require("../commands/config");
				await configInstall();
			} else if (subcommand === "update") {
				const { configUpdate } = require("../commands/config");
				await configUpdate();
			} else if (subcommand === "switch") {
				const { configSwitch } = require("../commands/config");
				await configSwitch();
			} else {
				console.log("Unknown config subcommand. Try:\n  wp-env-bin config install\n  wp-env-bin config update\n  wp-env-bin config switch");
			}
			break;
		}
		case "install": {
			const { install } = require("../commands/install");
			await install();
			break;
		}
		case "setup": {
			const { setup } = require("../commands/setup");
			setup(process.argv.slice(3));
			break;
		}
		case "get": {
			if (subcommand === "db") {
				const { getRemoteDb } = require("../commands/get");
				await getRemoteDb();
			} else {
				console.log('Unknown subcommand. Try: wp-env-bin get db');
			}
			break;
		}
		case "process": {
			if (subcommand === "db") {
				const { processDb } = require("../commands/process");
				await processDb();
			} else {
				console.log('Unknown subcommand. Try: wp-env-bin process db');
			}
			break;
		}
		case "make": {
			if (subcommand === "htaccess") {
				const { makeHtaccess } = require("../commands/make");
				await makeHtaccess();
			} else {
				console.log('Unknown subcommand. Try: wp-env-bin make htaccess');
			}
			break;
		}
		case "use": {
			if (subcommand === "db") {
				const { useDb } = require("../commands/use");
				await useDb(process.argv[4]);
			} else {
				console.log("Unknown subcommand. Try: wp-env-bin use db <path/to/file.sql>");
			}
			break;
		}
		case "sync": {
			const { getRemoteDb } = require("../commands/get");
			const { processDb } = require("../commands/process");
			const { makeHtaccess } = require("../commands/make");
			const { activateComposerPlugins } = require("../commands/plugins");
			await getRemoteDb();
			await processDb();
			await makeHtaccess();
			await activateComposerPlugins();
			break;
		}
		case "env": {
			const argv = process.argv.slice(3);
			if (!argv.length || argv[0] === "help" || argv[0] === "--help" || argv[0] === "-h") {
				const { envHelp } = require("../commands/env");
				envHelp();
			} else {
				const { runWpEnv } = require("../commands/env");
				runWpEnv(argv);
			}
			break;
		}
		case "compare": {
			const argv = process.argv.slice(3);
			if (argv[0] === "help" || argv[0] === "--help" || argv[0] === "-h") {
				const { compareHelp } = require("../commands/compare");
				compareHelp();
			} else {
				const { compare } = require("../commands/compare");
				await compare(argv);
			}
			break;
		}
		case "e2e": {
			if (subcommand === "help" || subcommand === "--help" || subcommand === "-h") {
				const { e2eHelp } = require("../commands/e2e");
				e2eHelp();
			} else if (subcommand === "env") {
				const envArgs = process.argv.slice(4);
				if (!envArgs.length || envArgs[0] === "help" || envArgs[0] === "--help" || envArgs[0] === "-h") {
					const { e2eEnvHelp } = require("../commands/env");
					e2eEnvHelp();
				} else {
					const { runWpEnvE2e } = require("../commands/env");
					runWpEnvE2e(envArgs);
				}
			} else if (subcommand === "init") {
				const { initE2e } = require("../commands/e2e");
				await initE2e();
			} else if (subcommand === "generate") {
				const type = process.argv[4]; // "editor" or "frontend"
				const { generateE2eTests } = require("../commands/e2e");
				generateE2eTests(type, process.argv.slice(5));
			} else if (subcommand === "test") {
				const { runE2eTests } = require("../commands/e2e");
				runE2eTests(process.argv.slice(4));
			} else {
				console.log('Unknown e2e subcommand. Try:\n  wp-env-bin e2e init\n  wp-env-bin e2e test [--project=all-blocks-editor|all-blocks-frontend]\n  wp-env-bin e2e generate editor|frontend --file=path/to/block.json');
			}
			break;
		}
		case "help":
		default: {
			const { help } = require("../commands/help");
			help();
			break;
		}
	}
}

init().catch((err) => {
	console.error(err.message || err);
	process.exit(1);
});
